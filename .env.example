JWT_SECRET_BASE64=replace-with-base64-hs256-secret
RECAPTCHA_SECRET_KEY=replace-with-recaptcha-secret
RECAPTCHA_SITE_KEY=replace-with-recaptcha-site-key

DB_MASTER_URL=jdbc:mysql://mysql-primary:3306/moviedb?autoReconnect=true&allowPublicKeyRetrieval=true&useSSL=false&cachePrepStmts=true
DB_MASTER_USER=replace-with-db-master-user
DB_MASTER_PASSWORD=replace-with-db-master-password
DB_SLAVE_URL=jdbc:mysql://mysql-secondary:3306/moviedb?autoReconnect=true&allowPublicKeyRetrieval=true&useSSL=false&cachePrepStmts=true
DB_SLAVE_USER=replace-with-db-slave-user
DB_SLAVE_PASSWORD=replace-with-db-slave-password

IMPORT_DB_URL=jdbc:mysql://localhost:3306/moviedb?useUnicode=true&characterEncoding=ISO-8859-1
IMPORT_DB_USER=replace-with-import-db-user
IMPORT_DB_PASSWORD=replace-with-import-db-password
